      <column caption='DELIVERY STATUS' datatype='string' name='[Calculation_0990954568667136]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Delivery_Time_Min] &lt;= 30 THEN&#13;&#10;&quot;Fast&quot;&#13;&#10;ELSE&#13;&#10;&quot;Delayed&quot;&#13;&#10;END' />
      </column>
      <column caption='LOSS ORDERS' datatype='string' name='[Calculation_0990954569109505]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Profit] &lt; 0 THEN&#13;&#10;&quot;Loss&quot;&#13;&#10;ELSE&#13;&#10;&quot;Profit&quot;&#13;&#10;END' />
      </column>
      <column caption='TOP N FILTER' datatype='boolean' name='[Calculation_0990954570592259]' role='measure' type='nominal'>
        <calculation class='tableau' formula='RANK(SUM([Sales])) &lt;= [Parameters].[Parameter 0990954569871362]'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Average Sales per City' datatype='real' name='[Calculation_0990954571321348]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [City] : AVG([Sales]) }' />
      </column>
      <column caption='Average Product Sales' datatype='real' name='[Calculation_0990954571522053]' role='measure' type='quantitative'>
